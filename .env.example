# .env.example — Copia este archivo a .env y rellena tus credenciales.
# NUNCA pongas claves reales en este archivo. Solo .env (que está en .gitignore).

# ── Base de datos PostgreSQL (SNOMED IRBD) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=snomed_irbd
DB_USER=postgres
DB_PASSWORD=snomed_password

# ── Google Gemini (obligatorio — pipeline principal) ──────────────────────────
# Gratis: 1500 req/día con gemini-2.5-flash
# Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_google_api_key_aqui

# ── Groq (gratuito, open source — benchmark) ──────────────────────────────────
# Sin tarjeta de crédito. Registro en: https://console.groq.com
# Modelos: Llama 3.3, Gemma 2, Mistral, DeepSeek R1
GROQ_API_KEY=tu_groq_api_key_aqui

# ── OpenAI (opcional, de pago) ────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_openai_api_key_aqui

# ── Anthropic (opcional, de pago) ─────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui

# ── Ollama (modelos locales, sin API key) ─────────────────────────────────────
# Levantar: docker compose up ollama -d
OLLAMA_BASE_URL=http://localhost:11434
